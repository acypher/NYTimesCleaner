# Copy to scripts/release.env and fill in values. release.env is gitignored.
#
# NewsMinus can reuse OAuth credentials from NunusCursor/scripts/release.env.
# If that file exists at ../nunus/NunusCursor/scripts/release.env, these vars
# are optional unless you need overrides.
#
# Check what's missing:
#   ./scripts/check-release-credentials.sh

# --- Chrome Web Store (NewsMinus listing) ---
# https://chromewebstore.google.com/detail/nytimes-cleaner/hkiiglaagokcdpagbblfhmdobblfelpn
# CWS_EXTENSION_ID=hkiiglaagokcdpagbblfhmdobblfelpn
# OAuth (usually inherited from Nunus release.env):
# CWS_CLIENT_ID=
# CWS_CLIENT_SECRET=
# CWS_REFRESH_TOKEN=

# --- Firefox AMO ---
# AMO_JWT_ISSUER=
# AMO_JWT_SECRET=
# AMO_ADDON_ID=nytimescleaner@nunus.extension
# AMO_CHANNEL=listed

# --- Optional overrides ---
# NEWSMINUS_RELEASE_ENV=/path/to/custom/release.env
# NUNUS_RELEASE_ENV=/path/to/nunus/NunusCursor/scripts/release.env
